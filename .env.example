APP_NAME="Family Gathering System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

FAMGATH_DB_CONNECTION=pgsql
FAMGATH_DB_HOST=127.0.0.1
FAMGATH_DB_PORT=5432
FAMGATH_DB_DATABASE=your-db-name
FAMGATH_DB_USERNAME=your-db-user
FAMGATH_DB_PASSWORD=your-db-password

# Set this to your actual Vercel deployment URL before going live.
# Multiple origins (comma-separated): https://app.vercel.app,https://preview.vercel.app
CORS_ALLOWED_ORIGINS=https://your-next-app.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=error

FILESYSTEM_DISK=local

CACHE_STORE=file
SESSION_DRIVER=array
QUEUE_CONNECTION=sync

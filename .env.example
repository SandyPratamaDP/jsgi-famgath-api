APP_NAME="Family Gathering System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=your-db-name
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

# Set this to your actual Vercel deployment URL before going live.
# Multiple origins (comma-separated): https://app.vercel.app,https://preview.vercel.app
CORS_ALLOWED_ORIGINS=https://your-next-app.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=error

FILESYSTEM_DISK=local

CACHE_STORE=file
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
